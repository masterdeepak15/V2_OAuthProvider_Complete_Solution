@page "/Account/SetPassword"
@model OAuthProviderV2.Pages.Account.SetPasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Set Your Password — OAuth Provider</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="/app.css"/>
    <style>
        body { background: #f8f9fc; }
        .auth-card { width: 420px; max-width: 95vw; border-radius: 16px; border: none;
                     box-shadow: 0 4px 28px rgba(0,0,0,.11); }
        .brand-icon { width: 56px; height: 56px; border-radius: 14px;
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            display:flex; align-items:center; justify-content:center; font-size:26px;
            margin:0 auto 12px; box-shadow:0 4px 12px rgba(99,102,241,.3); }
        .btn-primary-grad { background: linear-gradient(135deg,#6366f1,#8b5cf6); border:none;
            border-radius:10px; font-weight:600; padding:11px; }
        .btn-primary-grad:hover { opacity:.92; }
    </style>
</head>
<body>
<div class="min-vh-100 d-flex align-items-center justify-content-center p-3">
    <div class="auth-card card">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="brand-icon">🔐</div>
                <h5 class="fw-bold mb-1">OAuth Provider</h5>
            </div>

            @if (Model.Success)
            {
                <div class="text-center">
                    <div style="font-size:42px;">✅</div>
                    <h6 class="fw-bold mt-2">Password set!</h6>
                    <p class="text-muted small">Your account is now active and your email is verified.</p>
                    <a href="/Account/Login" class="btn btn-primary-grad text-white w-100 mt-2">Continue to Sign In</a>
                </div>
            }
            else if (!Model.TokenValid)
            {
                <div class="text-center">
                    <div style="font-size:42px;">⚠️</div>
                    <h6 class="fw-bold mt-2">Link invalid or expired</h6>
                    <p class="text-muted small">This password link is no longer valid. Please ask your administrator to send a new invite.</p>
                    <a href="/Account/Login" class="btn btn-outline-secondary w-100 mt-2">Back to Sign In</a>
                </div>
            }
            else
            {
                <h6 class="fw-bold mb-1 text-center">Set your password</h6>
                <p class="text-muted small text-center mb-4">
                    @if (!string.IsNullOrEmpty(Model.Email)) { <text>for <strong>@Model.Email</strong></text> }
                </p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger small py-2">@Model.ErrorMessage</div>
                }

                <form method="post" asp-page-handler="">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Token" value="@Model.Token"/>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">New password</label>
                        <input type="password" name="password" class="form-control" required minlength="8"
                               placeholder="At least 8 characters"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Confirm password</label>
                        <input type="password" name="confirmPassword" class="form-control" required minlength="8"
                               placeholder="Re-enter your password"/>
                    </div>
                    <button type="submit" class="btn btn-primary-grad text-white w-100">Set Password &amp; Activate</button>
                </form>
            }
        </div>
    </div>
</div>
</body>
</html>
